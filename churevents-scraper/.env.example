# GEMINI_API_KEY: Required for Gemini AI API calls / Erforderlich für Live Gemini API Abfragen.
# Trage deinen API Key im AI Studio UI unter "Settings / Secrets" ein, damit er bei der Ausführung geladen wird.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# Hier wird automatisch die Applet-URL zur Laufzeit injiziert.
APP_URL=

